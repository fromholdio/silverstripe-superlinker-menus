{
    "name": "fromholdio/silverstripe-superlinker-menus",
    "type": "silverstripe-vendormodule",
    "description": "Menu management built using the Superlinker foundation",
    "license": "BSD-3-Clause",
    "keywords": ["silverstripe", "link", "superlinker", "menus"],
    "homepage": "https://github.com/fromholdio/silverstripe-superlinker-menus",
    "support": {
        "issues": "https://github.com/fromholdio/silverstripe-superlinker-menus/issues"
    },
    "authors": [{
        "name": "Luke Fromhold",
        "homepage": "https://fromhold.io"
    }],
    "require": {
        "fromholdio/silverstripe-dependentgroupeddropdownfield": "^4.0.0",
        "fromholdio/silverstripe-externalurlfield": "^2.0.0",
        "fromholdio/silverstripe-globalanchors": "^2.1.0",
        "fromholdio/silverstripe-sortable": "^4.0.0",
        "fromholdio/silverstripe-superlinker": "^4.0.0",
        "symbiote/silverstripe-gridfieldextensions": "^5.0.3",
        "unclecheese/display-logic": "^4.0.0"
    },
    "autoload": {
        "psr-4": {
            "Fromholdio\\SuperLinkerMenus\\": "src/"
        }
    },
    "prefer-stable": true,
    "minimum-stability": "dev",
    "extra": {
        "branch-alias": {
            "dev-fixes/ss6-support": "6.0.x-dev"
        }
    }
}
